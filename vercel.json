{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "rewrites": [
    { "source": "/n/:id", "destination": "/api/n/:id" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/((?!api/|n/|sitemap.xml|robots.txt|assets/|.*\\.).*)", "destination": "/" }
  ]
}
